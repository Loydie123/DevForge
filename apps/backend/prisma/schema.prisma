datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "linux-musl-openssl-3.0.x"]
}

model Project {
  id            String         @id @default(uuid())
  name          String
  framework     String
  createdAt     DateTime       @default(now())
  collections   Collection[]
  history       History[]
  environments  Environment[]
  dbConnections DbConnection[] // Relation to DB connections
  errorLogs     ErrorLog[]     // Relation to exception logs
  logSources    LogSource[]    // Relation to watched log sources
  userId        String?
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  uptimeChecks  UptimeCheck[]  // Relation to Uptime checks
}

model Environment {
  id        String   @id @default(uuid())
  name      String   // e.g., "Development", "Production"
  variables String   // JSON string storing key-value pairs
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Collection {
  id          String         @id @default(uuid())
  name        String
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requests    SavedRequest[]
  createdAt   DateTime       @default(now())
}

model SavedRequest {
  id           String     @id @default(uuid())
  name         String
  method       String     // GET, POST, PUT, DELETE, etc.
  url          String
  headers      String     // JSON serialized headers
  body         String?    // JSON serialized body
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model History {
  id         String   @id @default(uuid())
  method     String
  url        String
  statusCode Int
  latencyMs  Int
  headers    String   // JSON serialized request headers
  body       String?  // JSON serialized request body
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model DbConnection {
  id           String           @id @default(uuid())
  name         String           // e.g., "Local Postgres", "Prod Mongo"
  type         String           // "postgres" | "mysql" | "mongodb"
  host         String
  port         Int
  database     String
  username     String
  password     String
  projectId    String
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queryHistory DbQueryHistory[]
  createdAt    DateTime         @default(now())
}

model DbQueryHistory {
  id           String       @id @default(uuid())
  query        String       // SQL statement or Mongo command string
  latencyMs    Int
  status       String       // "success" | "error"
  error        String?      // Error message if query failed
  rowsCount    Int?         // Number of rows returned/affected
  connectionId String
  connection   DbConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
}

model ErrorLog {
  id        String   @id @default(uuid())
  service   String   // e.g., "backend", "frontend", "event-bus"
  message   String
  stack     String?  @db.Text
  severity  String   // "low" | "medium" | "high" | "critical"
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model LogSource {
  id        String   @id @default(uuid())
  name      String   // e.g., "Nginx Access Log", "Next.js Build Log"
  filePath  String   // Absolute path on disk
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String?   // nullable for OAuth-only users
  name      String?
  avatarUrl String?
  githubId  String?   @unique
  role      String    @default("developer") // "admin" | "developer"
  projects  Project[]
  createdAt DateTime  @default(now())
}

model UptimeCheck {
  id        String         @id @default(uuid())
  name      String
  url       String
  interval  Int            @default(60) // check interval in seconds
  status    String         @default("unknown") // "up" | "down" | "unknown"
  latencyMs Int?
  projectId String
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  results   UptimeResult[]
  createdAt DateTime       @default(now())
}

model UptimeResult {
  id            String      @id @default(uuid())
  statusCode    Int?
  latencyMs     Int
  status        String      // "up" | "down"
  error         String?
  uptimeCheckId String
  uptimeCheck   UptimeCheck @relation(fields: [uptimeCheckId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}
