{
  "buildCommand": "pnpm --filter \"@devforge/*\" build && pnpm --filter devforge-frontend build",
  "outputDirectory": "apps/frontend/.next",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-production-a449.up.railway.app/api/:path*"
    }
  ]
}
