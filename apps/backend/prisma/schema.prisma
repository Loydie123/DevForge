datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id            String         @id @default(uuid())
  name          String
  framework     String
  createdAt     DateTime       @default(now())
  collections   Collection[]
  history       History[]
  environments  Environment[]
  dbConnections DbConnection[] // Relation to DB connections
  errorLogs     ErrorLog[]     // Relation to exception logs
  logSources    LogSource[]    // Relation to watched log sources
}

model Environment {
  id        String   @id @default(uuid())
  name      String   // e.g., "Development", "Production"
  variables String   // JSON string storing key-value pairs
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Collection {
  id          String         @id @default(uuid())
  name        String
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requests    SavedRequest[]
  createdAt   DateTime       @default(now())
}

model SavedRequest {
  id           String     @id @default(uuid())
  name         String
  method       String     // GET, POST, PUT, DELETE, etc.
  url          String
  headers      String     // JSON serialized headers
  body         String?    // JSON serialized body
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model History {
  id         String   @id @default(uuid())
  method     String
  url        String
  statusCode Int
  latencyMs  Int
  headers    String   // JSON serialized request headers
  body       String?  // JSON serialized request body
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model DbConnection {
  id           String           @id @default(uuid())
  name         String           // e.g., "Local Postgres", "Prod Mongo"
  type         String           // "postgres" | "mysql" | "mongodb"
  host         String
  port         Int
  database     String
  username     String
  password     String
  projectId    String
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queryHistory DbQueryHistory[]
  createdAt    DateTime         @default(now())
}

model DbQueryHistory {
  id           String       @id @default(uuid())
  query        String       // SQL statement or Mongo command string
  latencyMs    Int
  status       String       // "success" | "error"
  error        String?      // Error message if query failed
  rowsCount    Int?         // Number of rows returned/affected
  connectionId String
  connection   DbConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
}

model ErrorLog {
  id        String   @id @default(uuid())
  service   String   // e.g., "backend", "frontend", "event-bus"
  message   String
  stack     String?  @db.Text
  severity  String   // "low" | "medium" | "high" | "critical"
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model LogSource {
  id        String   @id @default(uuid())
  name      String   // e.g., "Nginx Access Log", "Next.js Build Log"
  filePath  String   // Absolute path on disk
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
